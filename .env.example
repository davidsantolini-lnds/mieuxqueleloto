# =============================================================================
# Variables d'environnement — Mieux que le Loto
# Copie ce fichier en `.env.local` pour le dev, et renseigne les vraies valeurs
# dans Vercel → Settings → Environment Variables pour la prod.
# Toutes les variables NEXT_PUBLIC_* sont injectées au build (côté client).
# =============================================================================

# URL publique du site (pour les liens de partage et l'OpenGraph).
NEXT_PUBLIC_SITE_URL=https://mieuxqueleloto.fr

# --- Google AdSense (en attente d'approbation) ------------------------------
# Identifiant client AdSense, format ca-pub-XXXXXXXXXXXXXXXX
# Le script AdSense n'est chargé QU'APRES consentement explicite du visiteur
# (bandeau RGPD — cf. components/ConsentBanner.tsx).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# (optionnel) ID du bloc d'annonce pour la barre du bas (data-ad-slot)
NEXT_PUBLIC_ADSENSE_BOTTOM_SLOT=

# --- Adsterra (approbation rapide 24-48h) -----------------------------------
# Clé de la zone banner Adsterra
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
